<odoo>
    <record id="view_picking_form_inherit_scan" model="ir.ui.view">
        <field name="name">stock.picking.form.scan.button</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">

            <!-- Tambahkan tombol di header -->
            <xpath expr="//button[@name='button_validate']" position="before">
                <button name="action_open_scan_wizard"
                        string="Scan Barang"
                        type="object"
                        class="btn-primary"
                        invisible="state == 'done'"/>
            </xpath>


        </field>
    </record>
</odoo>